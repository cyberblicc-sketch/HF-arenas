{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "regions": ["iad1", "sfo1", "lhr1"],
  "crons": [
    {
      "path": "/api/cron/resolve-markets",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/update-odds",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-yields",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-settlements",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/oracle-heartbeat",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/leaderboard-refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/waitlist-digest",
      "schedule": "0 9 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://huggyarena.xyz"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,DELETE,PATCH,POST,PUT,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://docs.huggyarena.xyz"
    },
    {
      "source": "/app",
      "destination": "https://app.huggyarena.xyz"
    }
  ],
  "redirects": [
    {
      "source": "/twitter",
      "destination": "https://x.com/HuggyArena",
      "permanent": false
    },
    {
      "source": "/discord",
      "destination": "https://discord.gg/huggyarena",
      "permanent": false
    },
    {
      "source": "/github",
      "destination": "https://github.com/HuggyArena/HF-arenas",
      "permanent": false
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://huggyarena.xyz",
    "NEXT_PUBLIC_APP_NAME": "HuggyDual",
    "NEXT_PUBLIC_CHAIN_IDS": "8453,42161,10",
    "NEXT_PUBLIC_ENVIRONMENT": "production"
  }
}
