{
  "name": "arena-hf-top-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "build:all": "turbo run build",
    "dev:all": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prisma:generate": "pnpm --dir prisma exec prisma generate",
    "prisma:migrate": "pnpm --dir prisma exec prisma migrate deploy",
    "contracts:build": "pnpm --dir packages/contracts run build",
    "contracts:test": "pnpm --dir packages/contracts run test",
    "relayer:dev": "pnpm --dir apps/relayer run start:dev",
    "indexer:dev": "pnpm --dir apps/indexer run start:dev",
    "subgraph:codegen": "pnpm --dir subgraph run codegen",
    "subgraph:build": "pnpm --dir subgraph run build"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "turbo": "^2.1.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "engines": {
    "node": "20.x"
  }
}
